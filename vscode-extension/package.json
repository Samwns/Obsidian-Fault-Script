{
  "name": "obsidian-fault-script",
  "displayName": "Obsidian Fault Script",
  "description": "Language support, diagnostics, autocomplete and run commands for OFS",
  "version": "1.0.4",
  "publisher": "Obsidian-Fault",
  "icon": "media/ofs.png",
  "license": "BSL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Samwns/Obsidian-Fault-Script.git"
  },
  "homepage": "https://github.com/Samwns/Obsidian-Fault-Script",
  "bugs": {
    "url": "https://github.com/Samwns/Obsidian-Fault-Script/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ofs",
        "aliases": [
          "OFS",
          "Obsidian Fault Script"
        ],
        "extensions": [
          ".ofs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/ofs.svg",
          "dark": "./media/ofs.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ofs",
        "scopeName": "source.ofs",
        "path": "./syntaxes/ofs.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ofs",
        "path": "./snippets/ofs.code-snippets"
      }
    ],
    "themes": [
      {
        "label": "Obsidian Fault Purple",
        "uiTheme": "vs-dark",
        "path": "./themes/obsidian-fault-purple-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "ofs.runNative",
        "title": "Run",
        "shortTitle": "Run",
        "category": "OFS",
        "icon": {
          "light": "./media/play-light.svg",
          "dark": "./media/play-dark.svg"
        }
      },
      {
        "command": "ofs.debugNative",
        "title": "Debug",
        "shortTitle": "Debug",
        "category": "OFS",
        "icon": {
          "light": "./media/ofs.svg",
          "dark": "./media/ofs.svg"
        }
      },
      {
        "command": "ofs.checkFile",
        "title": "Check",
        "shortTitle": "Check",
        "category": "OFS",
        "icon": {
          "light": "./media/check-light.svg",
          "dark": "./media/check-dark.svg"
        }
      },
      {
        "command": "ofs.pauseExecution",
        "title": "Pause Execution",
        "shortTitle": "Pause",
        "category": "OFS",
        "icon": {
          "light": "./media/ofs.svg",
          "dark": "./media/ofs.svg"
        }
      },
      {
        "command": "ofs.resumeExecution",
        "title": "Resume Execution",
        "shortTitle": "Resume",
        "category": "OFS",
        "icon": {
          "light": "./media/play-light.svg",
          "dark": "./media/play-dark.svg"
        }
      },
      {
        "command": "ofs.stopExecution",
        "title": "Stop Execution",
        "shortTitle": "Stop",
        "category": "OFS",
        "icon": {
          "light": "./media/check-light.svg",
          "dark": "./media/check-dark.svg"
        }
      }
    ],
    "debuggers": [
      {
        "type": "ofs-native",
        "label": "OFS Native",
        "languages": [
          "ofs"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "program": {
                "type": "string",
                "description": "Resolved automatically from the active .ofs file."
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the launched program."
              },
              "noDebug": {
                "type": "boolean",
                "default": false,
                "description": "Run without debugger attached."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "OFS: Executar arquivo atual",
            "type": "ofs-native",
            "request": "launch",
            "noDebug": true
          },
          {
            "name": "OFS: Depurar arquivo atual",
            "type": "ofs-native",
            "request": "launch"
          }
        ]
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "ofs.runNative",
          "when": "resourceLangId == ofs",
          "group": "navigation@1"
        },
        {
          "command": "ofs.debugNative",
          "when": "resourceLangId == ofs",
          "group": "navigation@2"
        },
        {
          "command": "ofs.pauseExecution",
          "when": "resourceLangId == ofs && ofs.executionRunning && !ofs.executionPaused",
          "group": "navigation@3"
        },
        {
          "command": "ofs.resumeExecution",
          "when": "resourceLangId == ofs && ofs.executionRunning && ofs.executionPaused",
          "group": "navigation@3"
        },
        {
          "command": "ofs.stopExecution",
          "when": "resourceLangId == ofs && ofs.executionRunning",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Obsidian Fault Script",
      "properties": {
        "ofs.path": {
          "type": "string",
          "default": "ofs",
          "description": "Path to OFS compiler executable."
        },
        "ofs.diagnosticsOnType": {
          "type": "boolean",
          "default": true,
          "description": "Run ofs check while typing (debounced)."
        },
        "ofs.autoInstallCompiler": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install OFS compiler on extension activation when it is missing."
        },
        "ofs.preferEmbeddedCompiler": {
          "type": "boolean",
          "default": true,
          "description": "Prefer compiler binary embedded in extension (bin/<platform>) before workspace/system compiler."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0"
  }
}
