{
  "name": "Obsidian Fault Script",
  "scopeName": "source.ofs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ofs",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ofs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ofs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ofs",
          "match": "\\b(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "attach {name} — highlight library name inside braces",
          "name": "meta.attach.ofs",
          "match": "\\battach\\s*\\{\\s*([A-Za-z_][A-Za-z0-9_.\\-]*)\\s*\\}",
          "captures": {
            "1": { "name": "entity.name.module.ofs" }
          }
        },
        {
          "comment": "attach {F:path} — highlight file path prefix",
          "name": "meta.attach.file.ofs",
          "match": "\\battach\\s*\\{\\s*([Ff](?:ile)?):([^}]+)\\}",
          "captures": {
            "1": { "name": "keyword.operator.ofs" },
            "2": { "name": "string.unquoted.ofs" }
          }
        },
        {
          "name": "keyword.control.ofs",
          "match": "\\b(core|vein|forge|const|monolith|impl|namespace|strata|if|else|while|cycle|match|case|default|return|break|continue|throw|tremor|catch|fracture|abyss|bedrock|obsid|intent|tectonic|pure|impure|fractal|extern|rift|attach|import|as|layout|bind|abi|packed|native|system|asm|echo|in|shard)\\b"
        },
        {
          "name": "constant.language.boolean.ofs",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ofs",
          "match": "\\b(stone|u8|u16|u32|u64|i8|i32|crystal|obsidian|bool|void|glyph|flow|truth|ptr|shard)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ofs",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
