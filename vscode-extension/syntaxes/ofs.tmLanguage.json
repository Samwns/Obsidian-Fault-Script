{
  "name": "Obsidian Fault Script",
  "scopeName": "source.ofs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ofs",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ofs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ofs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ofs",
          "match": "\\b(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ofs",
          "match": "\\b(core|vein|forge|const|if|else|while|cycle|match|case|default|return|break|continue|throw|tremor|catch|fracture|obsid|intent|pure|impure|fractal|extern|attach|import|as)\\b"
        },
        {
          "name": "constant.language.boolean.ofs",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ofs",
          "match": "\\b(stone|crystal|obsidian|bool|void|glyph|flow|truth|ptr|shard)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ofs",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
